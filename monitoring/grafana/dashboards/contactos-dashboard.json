{
  "id": null,
  "uid": "contactos-devops",
  "title": "Contactos DevOps - Monitoreo",
  "tags": ["devops", "contactos"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "panels": [

    {
      "id": 1,
      "title": "Estado de la Aplicación",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "ONLINE", "color": "green" } } },
            { "type": "value", "options": { "0": { "text": "OFFLINE", "color": "red" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "app_up",
          "legendFormat": "Backend",
          "refId": "A"
        }
      ]
    },

    {
      "id": 2,
      "title": "Total de Requests HTTP",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "http_requests_total",
          "legendFormat": "Requests",
          "refId": "A"
        }
      ]
    },

    {
      "id": 3,
      "title": "Total de Errores HTTP",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "http_errors_total",
          "legendFormat": "Errores",
          "refId": "A"
        }
      ]
    },

    {
      "id": 4,
      "title": "Contenedores en Ejecución",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "green", "value": 5 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "count(container_last_seen{image!=\"\", name!=\"\"})",
          "legendFormat": "Contenedores",
          "refId": "A"
        }
      ]
    },

    {
      "id": 5,
      "title": "CPU por Contenedor (%)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{image!=\"\", name!=\"\"}[1m]) * 100",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 6,
      "title": "Memoria por Contenedor (MB)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{image!=\"\", name!=\"\"} / 1024 / 1024",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 7,
      "title": "Requests por segundo (tasa)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "rate(http_requests_total[1m])",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ]
    },

    {
      "id": 8,
      "title": "Memoria del Proceso Backend (MB)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "process_memory_bytes{type=\"heapUsed\"} / 1024 / 1024",
          "legendFormat": "Heap Used",
          "refId": "A"
        },
        {
          "expr": "process_memory_bytes{type=\"heapTotal\"} / 1024 / 1024",
          "legendFormat": "Heap Total",
          "refId": "B"
        },
        {
          "expr": "process_memory_bytes{type=\"rss\"} / 1024 / 1024",
          "legendFormat": "RSS",
          "refId": "C"
        }
      ]
    }

  ]
}
